# =============================================================================
# MERN Service (UniVeranstaltungen) - Environment Variables
# =============================================================================
# Copy values into your shell or deployment secret store before running:
#   config/mern_service/install_mern_service.sh

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority

# Database name
MONGO_DB=univeranstaltungen

# Backend auth secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# EC2 public IP or domain where the MERN app is hosted
MERN_APP_HOST=

# -----------------------------------------------------------------------------
# Optional (features degrade gracefully if blank)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
DEEPAI_API_KEY=

# -----------------------------------------------------------------------------
# Optional deployment tuning
# -----------------------------------------------------------------------------
# MERN_REPO_URL=https://github.com/Advanced-Computer-Lab-2025/UniVeranstaltungen.git
# PORT=4000

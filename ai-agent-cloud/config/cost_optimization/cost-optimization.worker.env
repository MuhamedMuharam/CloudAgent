# Cost Optimization Worker runtime environment file (ECS/Fargate)
# OPENAI_API_KEY is not used by this worker.

# AWS configuration
AWS_REGION=us-east-1
# Optional static credentials (not recommended on ECS; use task role instead)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional profile for local runs
# AWS_PROFILE=

# Worker behavior
COST_OPTIMIZATION_LOG_LEVEL=INFO
COST_OPTIMIZATION_MODE=recommend_only
COST_OPTIMIZATION_INTERVAL_WEEKS=1

# Analysis window and metric period
COST_OPTIMIZATION_ANALYSIS_MINUTES=10080
COST_OPTIMIZATION_ANALYSIS_PERIOD_SECONDS=auto
COST_OPTIMIZATION_ADAPTIVE_BASE_PERIOD_SECONDS=900
COST_OPTIMIZATION_MAX_DATAPOINTS_PER_METRIC=1200

# Utilization thresholds
COST_OPTIMIZATION_CPU_IDLE_THRESHOLD_PERCENT=15.0
COST_OPTIMIZATION_CPU_HOT_THRESHOLD_PERCENT=70.0
COST_OPTIMIZATION_NETWORK_IDLE_THRESHOLD_BYTES_PER_PERIOD=150000.0

# Extended signals
COST_OPTIMIZATION_INCLUDE_MEMORY_DISK_SIGNALS=true
COST_OPTIMIZATION_MEMORY_PRESSURE_THRESHOLD_PERCENT=75.0
COST_OPTIMIZATION_DISK_PRESSURE_THRESHOLD_PERCENT=80.0
COST_OPTIMIZATION_SWAP_PRESSURE_THRESHOLD_PERCENT=50.0

# Fleet scope
COST_OPTIMIZATION_ALLOWED_FAMILIES=
COST_OPTIMIZATION_ALLOWED_INSTANCE_IDS=
COST_OPTIMIZATION_MAX_INSTANCES=100

# Candidate selection gates
COST_OPTIMIZATION_MIN_MONTHLY_SAVINGS_USD=10.0
COST_OPTIMIZATION_MIN_PRIMARY_DATAPOINTS=24
COST_OPTIMIZATION_MAX_ACTIONS_PER_RUN=2
COST_OPTIMIZATION_REQUIRE_DOWNSIZE_SIGNAL=true
COST_OPTIMIZATION_REQUIRE_NO_EXTENDED_FINDINGS=true

# Optional hard size floors (blank = no hard floor)
COST_OPTIMIZATION_MIN_CPU=
COST_OPTIMIZATION_MIN_RAM_GB=

# Take-action execution settings
COST_OPTIMIZATION_CREATE_BACKUP=true
COST_OPTIMIZATION_BACKUP_NAME_PREFIX=ai-agent-cost-opt
COST_OPTIMIZATION_NO_REBOOT_BACKUP=true
COST_OPTIMIZATION_ENSURE_SERVICE_CONTINUITY=true
COST_OPTIMIZATION_STRICT_SERVICE_CONTINUITY=false
COST_OPTIMIZATION_SERVICE_RECOVERY_TIMEOUT_SECONDS=420
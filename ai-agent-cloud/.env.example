# =============================================================================
# AI Agent Cloud Infrastructure - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Main controller agent model
MAIN_CONTROLLER_MODEL=gpt-5.4

# Observability helper agent model
OBSERVABILITY_HELPER_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# AWS Configuration (Required for AWS operations)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# Alternative: If using AWS CLI profiles, you can set:
# AWS_PROFILE=your-profile-name

# -----------------------------------------------------------------------------
# CloudWatch Observability Defaults (Optional but recommended)
# -----------------------------------------------------------------------------
# Default dashboard used by observability tooling and test harness.
CW_DASHBOARD_NAME=ai-agent-observability

# Default CloudWatch log group for application logs.
CW_TEST_LOG_GROUP=/ai-agent/app

# Default EC2 instance ID for metrics/alarm testing (set after instance launch).
# Example: i-0123456789abcdef0
CW_TEST_INSTANCE_ID=

# SNS topic ARN for alarm notifications and test alarm actions.
# Example: arn:aws:sns:us-east-1:123456789012:ai-agent-observability-alerts
CW_TEST_SNS_ARN=

# Whether the test harness should create a temporary CloudWatch alarm.
# Set to true only when you explicitly want to test alarm creation.
CW_CREATE_TEST_ALARM=false

# SQS queue URL consumed by alarm_worker.py (required for automatic alarm handling).
ALARM_SQS_QUEUE_URL=

# -----------------------------------------------------------------------------
# Alarm Worker Controls (Optional)
# -----------------------------------------------------------------------------
# Process only ALARM state notifications (skip OK/INSUFFICIENT_DATA).
ALARM_WORKER_PROCESS_ONLY_ALARM=true

# Polling behavior.
ALARM_WORKER_MAX_MESSAGES=1
ALARM_WORKER_WAIT_TIME_SECONDS=20
ALARM_WORKER_VISIBILITY_TIMEOUT=300
ALARM_WORKER_LOOP_SLEEP_SECONDS=2

# Acknowledge SQS messages only when the agent reports success.
ALARM_WORKER_REQUIRE_SUCCESS_FOR_ACK=true

# Number of agent attempts per notification before leaving message unacked.
ALARM_WORKER_AGENT_ATTEMPTS=1

# Mitigation mode and safety controls.
ALARM_WORKER_AUTO_MITIGATE=false
ALARM_WORKER_ALLOW_REBOOT_ON_STATUS_CHECK_FAILURE=false
ALARM_WORKER_ALLOW_DISK_CLEANUP_APPLY=false
ALARM_WORKER_TARGET_OS=amazon-linux-2023

# Comma-separated list of services allowed for auto-restart during mitigation.
# Example: real-api.service,real-worker.service,otel-collector.service
ALARM_WORKER_RESTART_SERVICES=

# -----------------------------------------------------------------------------
# Cost Optimization Scheduled Service (Optional)
# -----------------------------------------------------------------------------
# This service is designed for systemd timer execution (one-shot runs).
# It uses existing MCP cost tools to analyze fleet rightsizing opportunities.

# Mode:
# - recommend_only : generate analysis/recommendations only
# - take_action    : automatically apply qualifying rightsizing actions
COST_OPTIMIZATION_MODE=recommend_only

# Weekly/biweekly cadence control:
# - Keep timer weekly (OnCalendar below)
# - Set to 2 to execute every 2 weeks (runner skips in-between weeks)
COST_OPTIMIZATION_INTERVAL_WEEKS=1

# systemd timer schedule expression (OnCalendar format)
# Example weekly Sunday 03:00 UTC:
COST_OPTIMIZATION_ON_CALENDAR="Sun *-*-* 03:00:00"

# Random start jitter in seconds to avoid synchronized runs across fleets
COST_OPTIMIZATION_RANDOMIZED_DELAY_SECONDS=1800

# Run one immediate service execution after installer enables timer
COST_OPTIMIZATION_RUN_ON_INSTALL=true

# Linux user used by systemd service unit
COST_OPTIMIZATION_SERVICE_USER=ec2-user

# Worker logging level
COST_OPTIMIZATION_LOG_LEVEL=INFO

# Fleet analysis scope
COST_OPTIMIZATION_MAX_INSTANCES=100

# Optional allow-lists (comma-separated). Empty = all instances/families.
COST_OPTIMIZATION_ALLOWED_INSTANCE_IDS=
COST_OPTIMIZATION_ALLOWED_FAMILIES=

# Analysis window and thresholds
# Weekly window default (7 days = 10080 minutes)
COST_OPTIMIZATION_ANALYSIS_MINUTES=10080
# Set to auto for adaptive period, or set explicit seconds (must be >= 60)
COST_OPTIMIZATION_ANALYSIS_PERIOD_SECONDS=auto
# Adaptive baseline period used when period is auto
COST_OPTIMIZATION_ADAPTIVE_BASE_PERIOD_SECONDS=900
# Target maximum datapoints per metric query when period is auto
COST_OPTIMIZATION_MAX_DATAPOINTS_PER_METRIC=600
COST_OPTIMIZATION_CPU_IDLE_THRESHOLD_PERCENT=15.0
COST_OPTIMIZATION_CPU_HOT_THRESHOLD_PERCENT=70.0
# Bursty workload guard: never downsize if cpu_max exceeded this % even if avg was low
COST_OPTIMIZATION_CPU_PEAK_CAP_PERCENT=50.0
# Period-normalized network idle threshold (bytes/sec). Effective threshold =
# bytes_per_second × resolved_period_seconds, so it stays accurate regardless of window.
# 555 b/s × 900 s = ~499 KB/period, safely above idle agent background noise.
COST_OPTIMIZATION_NETWORK_IDLE_THRESHOLD_BYTES_PER_SECOND=555.0

# Extended memory/disk/swap signals
COST_OPTIMIZATION_INCLUDE_MEMORY_DISK_SIGNALS=true
COST_OPTIMIZATION_MEMORY_PRESSURE_THRESHOLD_PERCENT=75.0
COST_OPTIMIZATION_DISK_PRESSURE_THRESHOLD_PERCENT=80.0
COST_OPTIMIZATION_SWAP_PRESSURE_THRESHOLD_PERCENT=50.0

# Automatic action safety gates
COST_OPTIMIZATION_MIN_MONTHLY_SAVINGS_USD=5.0
COST_OPTIMIZATION_MIN_DATA_HOURS=3
COST_OPTIMIZATION_SKIP_CROSS_FAMILY_OPTIMIZATION=true
COST_OPTIMIZATION_REQUIRE_DOWNSIZE_SIGNAL=true
COST_OPTIMIZATION_REQUIRE_NO_EXTENDED_FINDINGS=true
COST_OPTIMIZATION_MAX_ACTIONS_PER_RUN=2

# Optional minimum size constraints (blank means no extra hard minimum)
COST_OPTIMIZATION_MIN_CPU=
COST_OPTIMIZATION_MIN_RAM_GB=

# Rightsizing execution settings for take_action mode
COST_OPTIMIZATION_CREATE_BACKUP=true
COST_OPTIMIZATION_BACKUP_NAME_PREFIX=ai-agent-cost-opt
COST_OPTIMIZATION_NO_REBOOT_BACKUP=true
COST_OPTIMIZATION_ENSURE_SERVICE_CONTINUITY=true
COST_OPTIMIZATION_STRICT_SERVICE_CONTINUITY=false
COST_OPTIMIZATION_SERVICE_RECOVERY_TIMEOUT_SECONDS=420


# -----------------------------------------------------------------------------
# Azure Configuration (Future - not yet implemented)
# -----------------------------------------------------------------------------
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# -----------------------------------------------------------------------------
# GCP Configuration (Future - not yet implemented)
# -----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1


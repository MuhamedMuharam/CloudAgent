# =============================================================================
# AI Agent Cloud Infrastructure - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AWS Configuration (Required for AWS operations)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# Alternative: If using AWS CLI profiles, you can set:
# AWS_PROFILE=your-profile-name

# -----------------------------------------------------------------------------
# Azure Configuration (Future - not yet implemented)
# -----------------------------------------------------------------------------
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# -----------------------------------------------------------------------------
# GCP Configuration (Future - not yet implemented)
# -----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
